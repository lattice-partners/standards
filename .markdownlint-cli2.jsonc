{
  // Relaxed rules suited to prose-heavy standards docs.
  "config": {
    "default": true,
    "MD013": false, // line length: prose wraps naturally, don't enforce
    "MD024": { "siblings_only": true }, // allow repeated headings in different sections
    "MD033": false, // allow inline HTML (tables/diagrams)
    "MD041": false // first line need not be a top-level heading (symlinked files)
  },
  "ignores": ["node_modules"]
}
